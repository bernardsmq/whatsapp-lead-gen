        "authentication": "genericCredentialType",
        "method": "POST",
        "sendBody": true,
        "bodyParametersJson": "{\n  \"messaging_product\": \"whatsapp\",\n  \"recipient_type\": \"individual\",\n  \"to\": \"{{$node.Webhook.json.body.phone}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"Hi {{$node.Webhook.json.body.first_name}}, we found a car that matches your needs! Reply with your details: When do you need it? What car type? Short-term or long-term? How long?\"\n  }\n}",
        "headerParametersJson": "{\n  \"Authorization\": \"Bearer \"\n}"
      },
      "name": "Send WhatsApp Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "operation": "create",
        "table": "conversations",
        "columns": "{\n  \"lead_id\": \"{{$node.Webhook.json.body.lead_id}}\",\n  \"message_type\": \"outgoing\",\n  \"sender\": \"system\",\n  \"content\": \"Hi {{$node.Webhook.json.body.first_name}}, we found a car that matches your needs! Reply with your details: When do you need it? What car type? Short-term or long-term? How long?\"\n}"
      },
      "name": "Save to Supabase",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Webhook": {
